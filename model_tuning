
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import Conv1D, MaxPooling1D,  GlobalAveragePooling1D, Dense,  BatchNormalization, Dropout
import keras_tuner as kt
import tensorflow as tf
import numpy as np
import pandas as pd

# loading data
x_train = np.load("numpy_data/X_train.npy")
y_train = np.load("numpy_data/y_train.npy")
x_val = np.load("numpy_data/X_val.npy")
y_val = np.load("numpy_data/y_val.npy")

# data_augmentation
print("starting data augmentation")

# noise_function(SNR)
def add_noise_snr(signal, snr_db):
    sig_avg_watts = np.mean(signal**2)
    sig_avg_db = 10 * np.log10(sig_avg_watts)
    noise_avg_db = sig_avg_db - snr_db
    noise_avg_watts = 10 ** (noise_avg_db / 10)
    noise = np.random.normal(0, np.sqrt(noise_avg_watts), signal.shape)
    return signal + noise

# add noise to train_data
x_train_15db = np.array([add_noise_snr(x, 15) for x in x_train])
x_train_10db = np.array([add_noise_snr(x, 10) for x in x_train])

# combine data with 15dB_noise and 10dB_noise
x_train_aug = np.concatenate([x_train, x_train_15db, x_train_10db])
y_train_aug = np.concatenate([y_train, y_train, y_train])

# Normalisation
train_mean = x_train_aug.mean()
train_std = x_train_aug.std()
x_train_final = (x_train_aug - train_mean) / train_std
x_val_final = (x_val - train_mean) / train_std

def build_model(hp):
    model = Sequential()

    # block1_conv1D
    model.add(Conv1D(
        filters=hp.Int('conv_1_filter', min_value=16, max_value=64, step=16),
        kernel_size=3, activation='relu', padding='same', input_shape=(1024, 1)
    ))
    model.add(BatchNormalization())
    model.add(MaxPooling1D(pool_size=2))

    # block2_conv1D
    model.add(Conv1D(
        filters=hp.Int('conv_2_filter', min_value=32, max_value=128, step=32),
        kernel_size=3, activation='relu', padding='same'
    ))
    model.add(BatchNormalization())
    model.add(MaxPooling1D(pool_size=2))

    model.add(GlobalAveragePooling1D())

    # block1_dense
    model.add(Dense(
        units=hp.Int('dense_units', min_value=64, max_value=256, step=64),
        activation='relu'
    ))

    # Dropout
    model.add(Dropout(rate=hp.Float('dropout_rate', min_value=0.2, max_value=0.5, step=0.1)))

    # block2_dense_Output
    model.add(Dense(4, activation='softmax'))

    # Learning Rate
    hp_learning_rate = hp.Choice('learning_rate', values=[1e-2, 1e-3, 1e-4])

    model.compile(
        optimizer=tf.keras.optimizers.Adam(learning_rate=hp_learning_rate),
        loss='sparse_categorical_crossentropy',
        metrics=['accuracy']
    )
    return model

# tuner_configuration
tuner = kt.Hyperband(
    build_model,
    objective='val_accuracy',
    max_epochs=20,
    factor=3,
    directory='tuning_results',
    project_name='cwru_optimization',
    overwrite=True
)

# EarlyStopping epochs if there is no progress
stop_early = tf.keras.callbacks.EarlyStopping(monitor='val_loss', patience=5)

# best_parameters_research
print("begin best parameters research")
tuner.search(x_train_final, y_train_aug, epochs=50, validation_data=(x_val_final, y_val), callbacks=[stop_early])

# best parameters recuperation
best_hps = tuner.get_best_hyperparameters(num_trials=1)[0]

print(f"""
End of resaerch
- Filtres Conv1: {best_hps.get('conv_1_filter')}
- Filtres Conv2: {best_hps.get('conv_2_filter')}
- Neurones Dense: {best_hps.get('dense_units')}
- Learning Rate: {best_hps.get('learning_rate')}
- Dropout: {best_hps.get('dropout_rate')}
""")
# Create model with the best parameters
model = tuner.hypermodel.build(best_hps)
model.summary()
