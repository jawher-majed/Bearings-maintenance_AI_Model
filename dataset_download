"""
CWRU Bearing Dataset Builder
Downloads all 12k Drive End .mat files (loads 0-3 HP)
and builds a windowed CSV dataset with train/val/test splits.

Splits:
    Train      -> loads 0, 1, 2 HP  (~75%)
    Validation -> load  3 HP first 40% of each bearing (~10%)
    Test       -> load  3 HP last  60% of each bearing (~15%)
"""

import os
import urllib.request
import scipy.io
import numpy as np
import pandas as pd


